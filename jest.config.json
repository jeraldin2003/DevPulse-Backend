{
  "testEnvironment": "node",
  "transform": {
    "^.+\\.js$": "babel-jest"
  },
  "testMatch": ["**/__tests__/**/*.test.js"],
  "collectCoverageFrom": [
    "src/**/*.js",
    "!src/index.js",
    "!src/config/**"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "lcov", "html"],
  "clearMocks": true
}
